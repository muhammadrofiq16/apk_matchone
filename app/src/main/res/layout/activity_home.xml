<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F9FAF5"
    tools:context=".ui.main.HomeActivity">

    <!-- HEADER / TOP APP BAR -->
    <LinearLayout
        android:id="@+id/topAppBar"
        android:layout_width="match_parent"
        android:layout_height="74dp"
        android:orientation="horizontal"
        android:gravity="bottom|center_horizontal"
        android:paddingHorizontal="16dp"
        android:background="#EDEEE9"
        android:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent">
        
        <ImageView
            android:id="@+id/ivLogo"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/logo" />
            
        <TextView
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="MatchOne"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#37563b"
            android:gravity="center"
            android:fontFamily="serif" />
            
        <ImageView
            android:id="@+id/btnHeaderCart"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@android:drawable/ic_menu_agenda"
            app:tint="#37563b" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/topAppBar"
        app:layout_constraintBottom_toTopOf="@id/bottomNavContainer"
        android:clipToPadding="false"
        android:paddingBottom="24dp">
        
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- HERO SECTION -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="480dp">
                
                <ImageView
                    android:id="@+id/ivHeroImage"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop" />
                    
                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="#44000000" />
                    
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ESTABLISHED IN TRADITION"
                        android:textColor="#c8ecc8"
                        android:textSize="12sp"
                        android:letterSpacing="0.1"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />
                        
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Your Daily\nRitual, Refined."
                        android:textColor="#FFFFFF"
                        android:textSize="36sp"
                        android:fontFamily="serif"
                        android:textStyle="bold"
                        android:lineSpacingExtra="4dp"
                        android:layout_marginBottom="16dp" />
                        
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Experience the calm energy of stone-ground Uji matcha. A moment of stillness in a fast-paced world."
                        android:textColor="#E0E0E0"
                        android:textSize="16sp"
                        android:layout_marginBottom="24dp" />
                        
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        
                        <Button
                            android:id="@+id/btnExploreBlends"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="56dp"
                            android:text="Explore Blends"
                            android:backgroundTint="#37563b"
                            android:textColor="#FFFFFF"
                            android:textAllCaps="false"
                            android:textSize="16sp"
                            app:cornerRadius="28dp"
                            android:layout_marginEnd="8dp" />
                            
                        <Button
                            android:id="@+id/btnLearnCraft"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="56dp"
                            android:text="Learn the Craft"
                            android:backgroundTint="#d4e5ca"
                            android:textColor="#53634d"
                            android:textAllCaps="false"
                            android:textSize="16sp"
                            app:cornerRadius="28dp"
                            android:layout_marginStart="8dp" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- CURATED COLLECTION TITLE -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="24dp"
                android:layout_marginTop="16dp"
                android:gravity="center_vertical">
                
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Curated Collection"
                        android:textColor="#1a1c19"
                        android:textSize="24sp"
                        android:fontFamily="serif"
                        android:textStyle="bold" />
                        
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Hand-selected grades for every occasion."
                        android:textColor="#424841"
                        android:textSize="14sp"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
                
                <TextView
                    android:id="@+id/btnViewAll"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="View All"
                    android:textColor="#37563b"
                    android:textStyle="bold"
                    android:textSize="16sp" />
            </LinearLayout>

            <!-- BENTO GRID - ITEM 1 (UJI GOLD) -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                app:cardBackgroundColor="#f3f4ef"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="BESTSELLER"
                        android:background="#4f6f52"
                        android:textColor="#ccf0cc"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="4dp" />
                        
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Uji Gold Ceremonial"
                        android:textColor="#1a1c19"
                        android:textSize="20sp"
                        android:fontFamily="serif"
                        android:textStyle="bold"
                        android:layout_marginTop="12dp" />
                        
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Our highest grade. Vibrant green, velvety texture, and a naturally sweet finish."
                        android:textColor="#424841"
                        android:textSize="14sp"
                        android:layout_marginTop="8dp"
                        android:maxWidth="200dp" />
                        
                    <ImageView
                        android:id="@+id/ivUjiGold"
                        android:layout_width="160dp"
                        android:layout_height="160dp"
                        android:layout_gravity="end"
                        android:layout_marginTop="-60dp" />
                        
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="$48.00"
                        android:textColor="#37563b"
                        android:textSize="28sp"
                        android:fontFamily="serif"
                        android:textStyle="bold"
                        android:layout_marginTop="-20dp" />
                        
                    <Button
                        android:id="@+id/btnAddToCartGold"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:text="Add to Cart"
                        android:backgroundTint="#37563b"
                        android:textColor="#FFFFFF"
                        android:textAllCaps="false"
                        app:cornerRadius="20dp"
                        android:layout_marginTop="16dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- BENTO GRID - ROW 2 (Latte & Culinary) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="16dp"
                android:baselineAligned="false">
                
                <!-- LATTE -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_weight="1.2"
                    android:layout_height="match_parent"
                    android:layout_marginEnd="8dp"
                    app:cardBackgroundColor="#edeee9"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp">
                    
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:padding="16dp">
                        
                        <ImageView
                            android:id="@+id/ivLatte"
                            android:layout_width="match_parent"
                            android:layout_height="120dp"
                            android:scaleType="centerCrop"
                            android:layout_marginBottom="12dp" />
                            
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Daily Ritual Latte"
                            android:textColor="#1a1c19"
                            android:textSize="16sp"
                            android:fontFamily="serif"
                            android:textStyle="bold" />
                            
                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_marginTop="16dp">
                            
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="$24.00"
                                android:textColor="#37563b"
                                android:textSize="20sp"
                                android:fontFamily="serif"
                                android:textStyle="bold"
                                android:layout_alignParentBottom="true" />
                                
                        </RelativeLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- CULINARY -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_weight="0.8"
                    android:layout_height="match_parent"
                    android:layout_marginStart="8dp"
                    app:cardBackgroundColor="#ffdcc0"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp">
                    
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:gravity="center_vertical">
                        
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Culinary\nGrade"
                            android:textColor="#2d1600"
                            android:textSize="16sp"
                            android:textStyle="bold" />
                            
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="$18.00"
                            android:textColor="#633f1a"
                            android:textSize="20sp"
                            android:fontFamily="serif"
                            android:layout_marginTop="8dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- RITUAL TRACKER -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="#e2e3de"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Active Ritual Delivery"
                        android:textColor="#1a1c19"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="16dp" />
                        
                    <ProgressBar
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:max="100"
                        android:progress="66"
                        android:progressTint="#37563b"
                        android:progressBackgroundTint="#c2c8bf" />
                        
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="8dp">
                        
                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="Harvest"
                            android:textSize="10sp"
                            android:gravity="center"
                            android:textColor="#1a1c19" />
                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="Steaming"
                            android:textSize="10sp"
                            android:gravity="center"
                            android:textColor="#1a1c19" />
                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="Grinding"
                            android:textSize="10sp"
                            android:gravity="center"
                            android:textColor="#1a1c19" />
                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="Shipping"
                            android:textSize="10sp"
                            android:gravity="center"
                            android:textColor="#737971" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- BREWING GUIDE -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="32dp"
                app:cardBackgroundColor="#edeee9"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    
                    <ImageView
                        android:id="@+id/ivBrewingGuide"
                        android:layout_width="match_parent"
                        android:layout_height="180dp"
                        android:scaleType="centerCrop" />
                        
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">
                        
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="The Art of Preparation"
                            android:textColor="#6d4722"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="4dp" />
                            
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Master the Whisk"
                            android:textColor="#1a1c19"
                            android:textSize="24sp"
                            android:fontFamily="serif"
                            android:textStyle="bold"
                            android:layout_marginBottom="12dp" />
                            
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Discover the meditative process of preparing the perfect bowl of matcha. From temperature control to the precise 'M' motion whisking technique."
                            android:textColor="#424841"
                            android:textSize="14sp"
                            android:layout_marginBottom="16dp" />
                            
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Enter the Guide →"
                            android:textColor="#37563b"
                            android:textStyle="bold"
                            android:textSize="14sp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

    <!-- BOTTOM NAVIGATION -->
    <include
        layout="@layout/bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="76dp"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
